# Copy to wrangler.toml [vars] or set via dashboard. Secrets via: wrangler secret put NAME

# Public website origin (redirects after login / logout). No trailing slash.
BASE_URL=https://hns.gg

# Discord server snowflake (Developer Portal → Server ID).
DISCORD_GUILD_ID=

# OAuth2 → General → Application ID
DISCORD_CLIENT_ID=

# wrangler secret put DISCORD_CLIENT_SECRET
# DISCORD_CLIENT_SECRET=

# wrangler secret put SESSION_SECRET — long random string (UTF-8); used for HMAC session + AES token encryption
# SESSION_SECRET=

# Optional: cookie Domain=.hns.gg so session is shared with subdomains. Omit for localhost.
# COOKIE_DOMAIN=.hns.gg

# Register OAuth redirect URL in Discord Developer Portal:
#   https://<auth-worker-host>/auth/callback
# If the auth Worker is routed at https://hns.gg/auth/*, use:
#   https://hns.gg/auth/callback
