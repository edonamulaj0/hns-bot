# Public site URL (no trailing slash). Used for auth/session fetch and absolute links.
# Example: https://hns.gg
NEXT_PUBLIC_BASE_URL=

# Bot / API Worker origin for server-side fetch and optional browser rewrites.
# Example: https://api.hns.gg  or  https://hns-bot.your-subdomain.workers.dev
# In development, if unset or placeholder, some API calls return empty data (production)
# or throw if NEXT_PUBLIC_API_URL contains YOUR_SUBDOMAIN (development).
NEXT_PUBLIC_API_URL=

# Same as HNS_WORKER_URL for Vercel/CI; Next prefers this for server fetches when set.
HNS_WORKER_URL=

# Discord server id — widget iframe and OAuth membership checks.
NEXT_PUBLIC_DISCORD_GUILD_ID=

# OAuth application client id (public). Shown in UI; auth flow uses the auth Worker.
NEXT_PUBLIC_DISCORD_CLIENT_ID=
