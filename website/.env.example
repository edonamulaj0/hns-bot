# Cloudflare Worker origin (no trailing slash). Used for Next.js rewrites and server-side fetch.
# Prefer HNS_WORKER_URL on Vercel so the value is not required in the browser bundle.
# Example: https://hns-bot.your-subdomain.workers.dev
HNS_WORKER_URL=
# Optional alias (exposed to the browser). If unset, local dev defaults to http://127.0.0.1:8787 via rewrites.
NEXT_PUBLIC_API_URL=
# Discord server ID for the official widget iframe (https://discord.com/widget?id=…)
NEXT_PUBLIC_DISCORD_GUILD_ID=
