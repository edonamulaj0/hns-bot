# ═══════════════════════════════════════════════════════════════════════════════
# Cloudflare Pages — set these in: Workers & Pages → your Pages project → Settings
# → Environment variables → Production (and Preview if you use branch previews).
#
# Bot API: set HNS_WORKER_URL or NEXT_PUBLIC_API_URL in Pages (runtime). Middleware proxies /hns-api/* → Worker
# (fixes 404 when the URL was missing at next build). next.config rewrites are optional if middleware runs.
# /auth/* uses the same middleware pattern + HNS_AUTH_WORKER_URL or NEXT_PUBLIC_AUTH_WORKER_URL (redeploy after changing).
# ═══════════════════════════════════════════════════════════════════════════════
#
# Variable                    Where to get the value
# --------------------------  --------------------------------------------------
# NEXT_PUBLIC_BASE_URL        Your live site: https://h4cknstack.com (no trailing slash).
#                             Must match auth Worker BASE_URL and Discord redirect host.
#
# NEXT_PUBLIC_API_URL         Bot Worker public URL, no trailing slash.
#                             Example: https://hns-bot.<account>.workers.dev
#                             Or custom: https://api.h4cknstack.com if you route it.
#                             Same value can go in HNS_WORKER_URL.
#
# HNS_WORKER_URL              Same as NEXT_PUBLIC_API_URL (server-side / CI parity).
#
# HNS_AUTH_WORKER_URL         Auth Worker URL, no trailing slash (e.g. https://hns-auth.<acct>.workers.dev).
# NEXT_PUBLIC_AUTH_WORKER_URL Same value if you prefer; middleware proxies /auth/* on Pages.
#                             Required for /auth/login on *.pages.dev and your custom domain unless
#                             you use a Worker route on the zone for /auth/* only.
#
# NEXT_PUBLIC_DISCORD_GUILD_ID  Discord server snowflake (widget + docs).
# NEXT_PUBLIC_DISCORD_CLIENT_ID OAuth2 “Client ID” (public; same app as bot).
#
# ═══════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_BASE_URL=https://h4cknstack.com

# After first `wrangler deploy` for the bot Worker, paste its URL:
NEXT_PUBLIC_API_URL=
HNS_WORKER_URL=

# After `cd auth && wrangler deploy`, paste auth Worker URL:
HNS_AUTH_WORKER_URL=
NEXT_PUBLIC_AUTH_WORKER_URL=

NEXT_PUBLIC_DISCORD_GUILD_ID=
NEXT_PUBLIC_DISCORD_CLIENT_ID=
