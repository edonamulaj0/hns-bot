{
  "name": "hns-bot",
  "private": true,
  "workspaces": [
    "website",
    "auth"
  ],
  "dependencies": {
    "@prisma/adapter-d1": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@prisma/config": "^7.7.0",
    "discord-api-types": "^0.38.45",
    "discord-hono": "^0.21.1",
    "dotenv": "^17.4.1"
  },
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),{execSync}=require('child_process');if(fs.existsSync('node_modules/.bin/prisma'))execSync('npx prisma generate',{stdio:'inherit'})\"",
    "pages:wiki:build": "cd hns-wiki && corepack enable pnpm && pnpm install --frozen-lockfile && pnpm docs:build",
    "register": "npx tsx --env-file=.env src/register.ts",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "wrangler": "^4.16.0"
  }
}
