generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String        @id @default(cuid())
  discordId             String        @unique
  discordUsername       String?
  displayName           String?
  avatarHash            String?
  bio                   String?
  github                String?
  linkedin              String?
  techStack             Json?
  points                Int           @default(0)
  rank                  Int           @default(0)
  lastPulseMonth        String?
  profileCompletedAt    DateTime?
  githubAccessTokenEnc  String?
  githubRefreshTokenEnc String?
  githubTokenExpiresAt  DateTime?
  githubLinkedLogin     String?
  /** Encrypted Discord OAuth access token (for membership re-verification). */
  accessToken           String?
  tokenExpiresAt        DateTime?
  submissions           Submission[]
  blogs                 Blog[]
  enrollments           Enrollment[]
  votesCast             Vote[]        @relation("VoteVoter")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([profileCompletedAt])
}

model Challenge {
  id          String       @id @default(cuid())
  month       String
  track       String
  tier        String
  title       String
  description String
  resources   String?
  deliverables String      @default("")
  messageId   String?
  threadId    String?
  publishedAt DateTime     @default(now())
  createdAt   DateTime     @default(now())
  enrollments Enrollment[]
  submissions Submission[]

  @@unique([month, track, tier])
  @@index([month, track])
}

model Enrollment {
  id          String   @id @default(cuid())
  userId      String
  challengeId String
  enrolledAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
}

model Submission {
  id            String    @id @default(cuid())
  userId        String
  month         String
  tier          String
  title         String
  description   String
  repoUrl       String
  demoUrl       String?
  isApproved    Boolean   @default(false)
  votes         Int       @default(0)
  track         String    @default("DEVELOPER")
  challengeType String?
  qualityWeight Float     @default(1.0)
  attachmentUrl String?
  challengeId   String?
  redirectSlug  String?   @unique
  revealed      Boolean   @default(false)
  isLocked      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge Challenge? @relation(fields: [challengeId], references: [id])
  voteRecords Vote[]

  @@unique([userId, month, title])
  @@index([month, isApproved])
  @@index([challengeId])
}

model Blog {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  content   String?
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PendingDiscordAttachment {
  discordUserId String
  kind          String
  url           String
  filename      String?
  contentType   String?
  size          Int?
  expiresAt     DateTime

  @@id([discordUserId, kind])
  @@index([expiresAt])
}

model PendingGithubOAuth {
  state         String   @id
  discordUserId String
  expiresAt     DateTime

  @@index([expiresAt])
}

model Vote {
  id               String   @id @default(cuid())
  submissionId     String
  voterDiscordId   String
  createdAt        DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  voter      User       @relation("VoteVoter", fields: [voterDiscordId], references: [discordId], onDelete: Cascade)

  @@unique([submissionId, voterDiscordId])
  @@index([submissionId])
  @@index([voterDiscordId])
}

model Config {
  id                 String   @id @default(cuid())
  lastVoteFeedMonth  String?
  lastPublishMonth   String?
  lastChallengeMonth String?
  lastChallengeGenError String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RoleMapping {
  key       String   @id
  roleId    String
  guildId   String
  createdAt DateTime @default(now())
}
