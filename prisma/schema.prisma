generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String       @id @default(cuid())
  discordId    String       @unique
  bio          String?
  github       String?
  linkedin     String?
  techStack    Json?
  points       Int          @default(0)
  rank         Int          @default(0)
  lastPulseMonth String?    // Tracks if user has run /pulse this month (dedup)
  profileCompletedAt DateTime? // Set once on first /setup-profile save; canonical "has profile"
  submissions  Submission[]
  blogs        Blog[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([profileCompletedAt])
}

model Submission {
  id          String   @id @default(cuid())
  userId      String
  month       String
  tier        String
  title       String
  description String
  repoUrl     String
  demoUrl     String?
  isApproved  Boolean  @default(false)
  votes       Int      @default(0)
  // Hacker track fields
  track          String  @default("DEVELOPER") // "DEVELOPER" | "HACKER"
  challengeType  String? // For hacker submissions: "CTF_WRITEUP" | "TOOL_BUILD" | "VULN_RESEARCH" | "REDTEAM"
  qualityWeight Float   @default(1.0) // Admin-settable quality modifier (0.5=superficial, 1.0=default, 1.5=exceptional)
  attachmentUrl String? // Discord CDN URL for optional PDF/.txt/.md (URLs expire — re-upload to R2 recommended)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  voteRecords Vote[]

  @@unique([userId, month, title])
  @@index([month, isApproved])
}

model Blog {
  id        String   @id @default(cuid())
  userId    String
  title     String
  url       String
  content   String?  // Raw markdown from uploaded .txt / .md (optional)
  upvotes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Slash-command attachment carried across to modal submit (modal interaction has no command options)
model PendingDiscordAttachment {
  discordUserId String
  kind          String // "submit" | "share_blog"
  url           String
  filename      String?
  contentType   String?
  size          Int?
  expiresAt     DateTime

  @@id([discordUserId, kind])
  @@index([expiresAt])
}

// Vote model for submission voting (prevents duplicate votes)
model Vote {
  id             String   @id @default(cuid())
  submissionId   String
  voterDiscordId String
  createdAt     DateTime @default(now())

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, voterDiscordId])
  @@index([submissionId])
}

// Config table for cron idempotency tracking
model Config {
  id                 String   @id @default(cuid())
  lastVoteFeedMonth   String?  // Tracks last month vote feed was posted (cron dedup)
  lastPublishMonth   String?  // Tracks last month publish was announced (cron dedup)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
